APP_NAME=JobIntel

ENV=development

DATABASE_URL=postgresql+asyncpg://jobintel:jobintel@localhost:5432/jobintel

JWT_SECRET=supersecretkey
JWT_ALGORITHM=HS256

ADMIN_EMAIL=admin@jobintel.local
